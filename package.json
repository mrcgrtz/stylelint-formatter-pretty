{
  "name": "stylelint-formatter-pretty",
  "version": "4.0.1",
  "description": "A pretty Stylelint formatter.",
  "license": "MIT",
  "repository": "github:mrcgrtz/stylelint-formatter-pretty",
  "funding": [
    {
      "type": "kofi",
      "url": "https://ko-fi.com/mrcgrtz"
    },
    {
      "type": "liberapay",
      "url": "https://liberapay.com/mrcgrtz/"
    }
  ],
  "author": {
    "name": "Marc Görtz",
    "email": "git@marcgoertz.de",
    "url": "https://marcgoertz.de/"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "type": "module",
  "exports": "./index.js",
  "scripts": {
    "coverage": "mkdir -p coverage && node --test --experimental-test-coverage --test-reporter=lcov --test-reporter-destination=coverage/lcov.info",
    "prepare": "husky",
    "test": "xo && node --test --experimental-test-coverage"
  },
  "files": [
    "index.js"
  ],
  "keywords": [
    "stylelint",
    "stylelint-formatter",
    "formatter",
    "reporter",
    "lint",
    "validate"
  ],
  "dependencies": {
    "ansi-escapes": "^7.0.0",
    "log-symbols": "^7.0.0",
    "picocolors": "^1.0.0",
    "plur": "^6.0.0",
    "string-width": "^7.0.0",
    "supports-hyperlinks": "^4.4.0"
  },
  "devDependencies": {
    "husky": "^9.0.10",
    "lint-staged": "^16.1.0",
    "strip-ansi": "^7.1.0",
    "xo": "^1.0.5"
  },
  "peerDependencies": {
    "stylelint": ">=16.0.0"
  },
  "lint-staged": {
    "*.js": "xo --fix"
  },
  "xo": {
    "rules": {
      "unicorn/no-array-for-each": "off"
    }
  }
}
